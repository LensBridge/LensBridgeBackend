# Copy to .env and fill in. .env is gitignored.

# --- Postgres ---
POSTGRES_DB=lensbridge
POSTGRES_USER=lensbridge
POSTGRES_PASSWORD=change-me-strong-password

# --- App secrets ---
# Generate with: openssl rand -base64 32
JWT_SECRET=
ONBOARDING_SECRET=

# --- Cloudflare R2 ---
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=lensbridge-media
CLOUDFLARE_R2_PUBLIC_URL=https://media.lensbridge.tech

# --- SMTP (Purelymail) ---
MAIL_USERNAME=noreply@lensbridge.tech
MAIL_PASSWORD=

# --- Allowed CORS origins (full URLs, no trailing slash) ---
FRONTEND_BASEURL=https://lensbridge.tech
MUSALLAHBOARD_BASEURL=https://musallah.lensbridge.tech

# --- API docs (keep false in prod) ---
SPRINGDOC_API_DOCS_ENABLED=false
